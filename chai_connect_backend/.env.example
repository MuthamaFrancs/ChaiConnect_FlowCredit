# ChaiConnect backend — copy to .env and fill values
# PostgreSQL (Sequelize sync on startup)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chaiconnect
DB_USER=postgres
DB_PASS=your_password_here

# Server
PORT=5000

# ─── Safaricom Daraja (all apps: https://developer.safaricom.co.ke ) ─────────
# Create an app, get Consumer Key & Secret. For sandbox, use the sandbox credentials.

# sandbox | production (switches api.safaricom.co.ke vs sandbox.safaricom.co.ke)
MPESA_ENV=sandbox

# Optional override (defaults from MPESA_ENV)
# MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# Required for OAuth (B2C, STK, most APIs)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret

# Public HTTPS base where THIS server receives callbacks. No trailing slash.
# Local dev: use ngrok — e.g. https://abc123.ngrok-free.app
# Safaricom must reach: {MPESA_CALLBACK_BASE_URL}/api/mpesa/callback/b2c-result
MPESA_CALLBACK_BASE_URL=https://your-public-host.example

# ─── B2C (Business → Customer) — send money to farmer phones (disbursements) ─
# Organization shortcode that sends funds (from Daraja app / M-Pesa Org portal)
MPESA_B2C_SHORTCODE=600000
# API user initiator name (created in M-Pesa Org portal for B2C)
MPESA_B2C_INITIATOR_NAME=testapi
# Security credential = Initiator password encrypted with Safaricom public key (portal tool / docs)
MPESA_B2C_SECURITY_CREDENTIAL=your_encrypted_security_credential_string

# ─── STK Push (Lipa na M-Pesa) — collect payment from customer ─────────────────
# Often the same paybill/till shortcode + passkey from Daraja “Lipa na M-Pesa Online”
MPESA_STK_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_online_passkey

# Set to true to keep the FlowCredit UI on demo simulation even if B2C vars exist
# MPESA_USE_SIMULATION=true
